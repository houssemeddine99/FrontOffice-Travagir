<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
    xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/voyageView.css"
      fx:controller="frontoffice.controllers.views.AssociationsViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="🏢 Associations" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Load my association" onAction="#onLoadMyAssociation" styleClass="primary-button" />
        <Label fx:id="myAssociationLabel" text="" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="associationsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colName" text="Name" prefWidth="260" />
                <TableColumn fx:id="colCompanyCode" text="Company Code" prefWidth="180" />
                <TableColumn fx:id="colDiscount" text="Discount" prefWidth="120" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
