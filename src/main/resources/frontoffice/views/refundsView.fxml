<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
    xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/refundView.css"
      fx:controller="frontoffice.controllers.views.RefundsViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="💰 Refunds" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT" styleClass="refund-form-row">
        <TextField fx:id="reclamationIdField" promptText="Reclamation ID" prefWidth="140" styleClass="refund-input" />
        <TextField fx:id="amountField" promptText="Amount" prefWidth="140" styleClass="refund-input" />
        <TextField fx:id="reasonField" promptText="Reason" prefWidth="360" styleClass="refund-input" />
        <Button text="Submit" onAction="#onSubmit" styleClass="primary-button" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="refundsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colReclamationId" text="Reclamation" prefWidth="140" />
                <TableColumn fx:id="colAmount" text="Amount" prefWidth="120" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="140" />
                <TableColumn fx:id="colCreatedAt" text="Created" prefWidth="220" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Delete selected (pending)" onAction="#onDeleteSelected" styleClass="secondary-button" />
        <Label fx:id="statusLabel" text="" />
    </HBox>

</VBox>
