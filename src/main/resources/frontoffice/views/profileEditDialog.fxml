<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="12" alignment="TOP_CENTER" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontoffice.controllers.views.ProfileEditController" stylesheets="@../css/addUser.css" styleClass="form-card">

    <padding>
        <Insets top="16" right="20" bottom="16" left="20"/>
    </padding>

    <Label text="Edit Profile" styleClass="form-title" />

    <GridPane vgap="10" hgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="100" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>

        <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0" />
        <TextField fx:id="nameField" GridPane.rowIndex="0" GridPane.columnIndex="1" />

        <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0" />
        <TextField fx:id="emailField" GridPane.rowIndex="1" GridPane.columnIndex="1" />

        <Label text="Phone" GridPane.rowIndex="2" GridPane.columnIndex="0" />
        <TextField fx:id="phoneField" GridPane.rowIndex="2" GridPane.columnIndex="1" />

        <Label text="Image URL" GridPane.rowIndex="3" GridPane.columnIndex="0" />
        <TextField fx:id="imageUrlField" GridPane.rowIndex="3" GridPane.columnIndex="1" />
    </GridPane>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#onCancel" />
        <Button text="Save" onAction="#onSave" />
    </HBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
