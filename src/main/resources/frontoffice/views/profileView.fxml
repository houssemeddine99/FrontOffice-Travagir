<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" prefWidth="900" prefHeight="650"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="frontoffice.controllers.views.ProfileViewController"
      stylesheets="@../css/addUser.css" styleClass="form-card">

    <padding>
        <Insets top="30" right="40" bottom="30" left="40"/>
    </padding>

    <VBox spacing="5" alignment="CENTER_LEFT" styleClass="form-header">
        <Label text="My Profile" styleClass="form-title"/>
        <Label text="Update your personal information" styleClass="form-subtitle"/>
    </VBox>

    <Separator />

    <GridPane vgap="15" hgap="10">
        <columnConstraints>
            <ColumnConstraints prefWidth="120" />
            <ColumnConstraints hgrow="ALWAYS" />
        </columnConstraints>
        <Label text="Name" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="field-label"/>
        <Label fx:id="nameLabel" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="form-field"/>

        <Label text="Email" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="field-label"/>
        <Label fx:id="emailLabel" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="form-field"/>

        <Label text="Phone" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="field-label"/>
        <Label fx:id="phoneLabel" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="form-field"/>

        <Label text="Image" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="field-label"/>
        <ImageView fx:id="imageView" GridPane.rowIndex="3" GridPane.columnIndex="1" fitHeight="96" fitWidth="160" preserveRatio="true" />
    </GridPane>

    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Refresh" onAction="#onRefresh" styleClass="btn-cancel" />
        <Button text="Update" onAction="#onEdit" styleClass="btn-save" />
    </HBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
