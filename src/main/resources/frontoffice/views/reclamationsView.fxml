<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
    xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/voyageView.css"
      fx:controller="frontoffice.controllers.views.ReclamationsViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="📢 Reclamations" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="Reservation ID:" />
        <TextField fx:id="reservationIdField" promptText="e.g. 1" prefWidth="100" />
        <TextField fx:id="titleField" promptText="Title (min 5 chars)" prefWidth="220" />
        <TextField fx:id="descriptionField" promptText="Description" prefWidth="320" />
        <Button text="Submit" onAction="#onSubmit" styleClass="primary-button" />
    </HBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="reclamationsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colReservationId" text="Reservation" prefWidth="120" />
                <TableColumn fx:id="colTitle" text="Title" prefWidth="220" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="140" />
                <TableColumn fx:id="colPriority" text="Priority" prefWidth="120" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
