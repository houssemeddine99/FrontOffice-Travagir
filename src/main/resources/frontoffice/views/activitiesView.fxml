<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/voyageView.css"
      fx:controller="frontoffice.controllers.views.ActivitiesViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="🏄 Activities" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <TextField fx:id="voyageIdField" promptText="Voyage ID" prefWidth="120" />
                <Button text="🔄 Load" onAction="#onLoad" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="activitiesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colName" text="Name" prefWidth="200" />
                <TableColumn fx:id="colLocation" text="Location" prefWidth="150" />
                <TableColumn fx:id="colDuration" text="Hours" prefWidth="90" />
                <TableColumn fx:id="colPrice" text="Price" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
