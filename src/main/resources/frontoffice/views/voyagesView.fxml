<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
    xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/voyageView.css"
      fx:controller="frontoffice.controllers.views.VoyagesViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="🎫 Voyages" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <TextField fx:id="searchField" promptText="Search by title" />
                <Button text="Search" onAction="#onSearch" styleClass="secondary-button" />
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="voyagesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colTitle" text="Title" prefWidth="220" />
                <TableColumn fx:id="colDestination" text="Destination" prefWidth="150" />
                <TableColumn fx:id="colPrice" text="Price" prefWidth="100" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Label text="People:" />
        <TextField fx:id="peopleField" promptText="1" prefWidth="80" />
        <Button text="Book selected" onAction="#onBookSelected" styleClass="primary-button" />
        <Label fx:id="statusLabel" text="" />
    </HBox>

</VBox>
