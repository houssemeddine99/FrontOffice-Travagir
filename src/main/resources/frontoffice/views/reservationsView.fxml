<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox prefHeight="768" prefWidth="1376.0"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      stylesheets="@../css/voyageView.css"
      fx:controller="frontoffice.controllers.views.ReservationsViewController"
      spacing="25"
      styleClass="card">

    <VBox spacing="10">
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="header-label-container">
            <Label text="🎟️ Reservations" styleClass="header-label" />
            <Region HBox.hgrow="ALWAYS" />
            <HBox spacing="15" alignment="CENTER_RIGHT">
                <padding>
                    <Insets right="20" />
                </padding>
                <Button text="🔄 Refresh" onAction="#onRefresh" styleClass="secondary-button" />
            </HBox>
        </HBox>
    </VBox>

    <VBox VBox.vgrow="ALWAYS">
        <TableView fx:id="reservationsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="60" />
                <TableColumn fx:id="colVoyageId" text="Voyage" prefWidth="120" />
                <TableColumn fx:id="colPeople" text="People" prefWidth="120" />
                <TableColumn fx:id="colStatus" text="Status" prefWidth="180" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="Cancel selected" onAction="#onCancelSelected" styleClass="secondary-button" />
        <Label text="Set people:" />
        <TextField fx:id="peopleUpdateField" promptText="1" prefWidth="80" />
        <Button text="Update" onAction="#onUpdatePeople" styleClass="primary-button" />
        <Button text="Create reclamation" onAction="#onCreateReclamationForSelected" styleClass="add-user" />
    </HBox>

    <Label fx:id="statusLabel" text="" />

</VBox>
